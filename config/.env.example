# Copy to .env and fill in your values. NEVER commit .env to Git.
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/retail_demand_db
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1
S3_BUCKET_NAME=retail-demand-models
RDS_HOST=your-rds-instance.us-east-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=retail_demand_db
RDS_USER=admin
RDS_PASSWORD=YOUR_PASSWORD
API_HOST=0.0.0.0
API_PORT=8000
MLFLOW_TRACKING_URI=http://localhost:5000
